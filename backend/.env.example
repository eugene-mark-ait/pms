# Copy to .env and fill in. Never commit real secrets.

# Google Sign-In (same OAuth 2.0 "Web application" client as NEXT_PUBLIC_GOOGLE_CLIENT_ID)
GOOGLE_OAUTH2_CLIENT_ID=
GOOGLE_OAUTH2_CLIENT_SECRET=

# M-PESA Daraja (sandbox: https://developer.safaricom.co.ke/)
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
# Sandbox Lipa Na M-PESA Online passkey for test shortcode 174379 (from Daraja app)
MPESA_PASSKEY=
MPESA_SHORTCODE=174379
# Must be HTTPS and reachable by Safaricom (use ngrok in local dev)
# Example: https://abcd.ngrok-free.app/api/mpesa/callback/
MPESA_CALLBACK_URL=

# Copy to .env and fill in. Never commit real secrets.

# Google Sign-In (same OAuth 2.0 "Web application" client as NEXT_PUBLIC_GOOGLE_CLIENT_ID)
GOOGLE_OAUTH2_CLIENT_ID=
GOOGLE_OAUTH2_CLIENT_SECRET=

# M-PESA Daraja (sandbox: https://developer.safaricom.co.ke/)
# When true (default): OAuth + STK always use https://sandbox.safaricom.co.ke (sandbox keys only).
MPESA_DARAJA_FORCE_SANDBOX=true
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
# Sandbox Lipa Na M-PESA Online passkey for test shortcode 174379 (same Daraja app as consumer key)
MPESA_PASSKEY=
MPESA_SHORTCODE=174379
# Must be HTTPS and reachable by Safaricom (use ngrok in local dev)
# Example: https://abcd.ngrok-free.app/api/mpesa/callback/
MPESA_CALLBACK_URL=
# When true: never cache OAuth (always GET /oauth/v1/generate). Default in Django = MPESA_DARAJA_FORCE_SANDBOX.
MPESA_DARAJA_BYPASS_TOKEN_CACHE=true
# STK password timestamp YYYYMMDDHHmmss (Kenya local time for Daraja)
MPESA_STK_TIMESTAMP_TZ=Africa/Nairobi

# IntaSend (https://developers.intasend.com/) — when set, rent STK uses IntaSend (platform collection + 3%/97% split).
# Register this URL in the IntaSend dashboard: https://your-domain/api/payments/intasend/webhook/
INTASEND_PUBLISHABLE_KEY=
INTASEND_SECRET_KEY=
INTASEND_TEST_MODE=true
INTASEND_WEBHOOK_URL=
# Optional: if set, webhook requests must send the same value in X-Webhook-Secret or X-Intasend-Secret
INTASEND_WEBHOOK_SECRET=
# Must match the challenge set in IntaSend Dashboard → Webhooks (payload field "challenge")
INTASEND_WEBHOOK_CHALLENGE=
PLATFORM_COMMISSION_RATE=0.03
INTASEND_MIN_PAYOUT_KES=1

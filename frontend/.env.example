# Copy to .env.local and fill in. Do not commit .env.local.
# Next.js loads .env.local automatically.

# API (backend)
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Google OAuth – Client ID only (never put Client Secret in frontend).
# If the button shows "Not connected", add your app origin (e.g. http://localhost:3000)
# under Authorized JavaScript origins in Google Cloud Console. See docs/GOOGLE_OAUTH_SETUP.md.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

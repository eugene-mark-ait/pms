# Copy to .env.local and fill in. Do not commit .env.local.
# Next.js loads .env.local automatically.

# API (backend)
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Google Sign-In – Web Client ID only (must match backend GOOGLE_OAUTH2_CLIENT_ID).
# Client Secret lives on the server only: GOOGLE_OAUTH2_CLIENT_SECRET in backend .env.
# Add your app origin (e.g. http://localhost:3000) under Authorized JavaScript origins.
# See docs/GOOGLE_OAUTH_SETUP.md.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
